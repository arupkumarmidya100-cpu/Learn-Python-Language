# Take list input from the user
lst = input("Enter list elements separated by spaces: ").split()

# Create a reversed copy
rev_lst = lst.copy()
rev_lst.reverse()

# Compare both lists
if lst == rev_lst:
    print("The list is a palindrome.")
else:
    print("The list is not a palindrome.")